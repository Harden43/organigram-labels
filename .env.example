# Copy this to .env.local and fill in your values

# Supabase — get from supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini — get from aistudio.google.com/apikey (free)
GEMINI_API_KEY=your_gemini_api_key

# App PIN — set whatever PIN you want your team to use
APP_PIN=1234

# App secret for session signing (generate a random string)
NEXTAUTH_SECRET=your_random_secret_string_here
